    },
    {
      "id": "LehI9ot_-v6VDqe7gn9TF",
      "type": "text",
      "x": 3211.762754439992,
      "y": 1374.4226024498853,
      "width": 732.3944884033638,
      "height": 500,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "7OTEqobg2DXZgRKf0fN5w"
      ],
      "frameId": null,
      "index": "c05g",
      "roundness": null,
      "seed": 619017318,
      "version": 1123,
      "versionNonce": 20087154,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1781711455320,
      "link": null,
      "locked": false,
      "text": "Screen Reader\n        Keyboard shortcuts\n        Knowledge without visual        \n\n        Recreate the sr journey using keyboard shortcuts:\n                Missing/Improper headings\n                Language attribute\n                Fill a form\n                Interact with call-to-action buttons, with data tables (only\ntabular data)\n                Check alts, link texts, button text\n                Check common problematic elements, like CAPTCHA,\naccessibility overlays, unexpected screen changes and Flash content \n                Check that search functionality is present and functional\n                Check skiplinks (main content, navigation)\n                Check that automatic carousels and autoplay are disabled\n                Repeat the processo with another sr\n                Make the fixes and repeat test\n\n        Test when great changes or additions",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Screen Reader\n        Keyboard shortcuts\n        Knowledge without visual        \n\n        Recreate the sr journey using keyboard shortcuts:\n                Missing/Improper headings\n                Language attribute\n                Fill a form\n                Interact with call-to-action buttons, with data tables (only tabular data)\n                Check alts, link texts, button text\n                Check common problematic elements, like CAPTCHA, accessibility overlays, unexpected screen changes and Flash content \n                Check that search functionality is present and functional\n                Check skiplinks (main content, navigation)\n                Check that automatic carousels and autoplay are disabled\n                Repeat the processo with another sr\n                Make the fixes and repeat test\n\n        Test when great changes or additions",
      "autoResize": false,
      "lineHeight": 1.25
    },
